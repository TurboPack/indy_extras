# DPM package spec file
min dpm client version: 1.0.0
metadata:
  id: TaurusTLS_Developers.TaurusTLS
  version: 1.0.8
  description: TaurusTLS provides OpenSSL 3.x and 4.x support for Indy - Internet Direct
  icon: ..\..\TaurusTLS\logo\bullhead.png
  authors:
    - TaurusTLS Developers
  projectUrl: https://github.com/TaurusTLS-Developers/TaurusTLS
  repositoryUrl: https://github.com/TaurusTLS-Developers/TaurusTLS
  license: Mozilla Public License 1.1
  copyright: TaurusTLS Developers
  tags:
    - indy
    - TLS
  readme: README.md
variables:
  packagesource: d$compilerCodeName$
targetPlatforms:
  - compiler: delphi10.0
    platforms:
      - win32
      - win64
      - macos32
      - android
      - ios32
      - ios64
      - iossimulator
  - compiler: delphi10.1
    platforms:
      - win32
      - win64
      - android
      - ios32
      - ios64
      - iossimulator
  - compiler: delphi10.2
    platforms:
      - win32
      - win64
      - macos32
      - android
      - ios32
      - ios64
      - iossimulator
      - linux64
  - compiler: delphi10.3
    platforms:
      - win32
      - win64
      - macos32
      - macos64
      - android
      - android64
      - ios32
      - ios64
      - iossimulator
      - linux64
  - compiler: delphi10.4
    platforms:
      - win32
      - win64
      - macos64
      - android
      - android64
      - ios64
      - iossimulator
      - linux64
  - compiler: delphi11.0
    platforms:
      - win32
      - win64
      - macos64
      - macosarm64
      - android
      - android64
      - ios64
      - linux64
    variables:
      packagesource: d11
  - compiler: delphi12.0
    platforms:
      - win32
      - win64
      - macos64
      - macosarm64
      - android
      - android64
      - ios64
      - linux64
    variables:
      packagesource: d12
  - compiler: delphi13.0
    platforms:
      - win32
      - win64
      - winarm64ec
      - macos64
      - macosarm64
      - android
      - android64
      - linux64
    variables:
      packagesource: d13
templates:
  - name: default
    source:
      - src: ./LICENSE.md
      - src: ./LICENSE_MPL_1_1.txt
      - src: ./Modified_BSD_LICENSE.md
      - src: ./DifferencesBetweenIndyOpenSSLAndTaurusTLS.md
      - src: ./What_needs_to_be_done.MD
      - src: ./Source/TaurusTLS.pas
      - src: ./Source/TaurusTLSConsts.pas
      - src: ./Source/TaurusTLSExceptionHandlers.pas
      - src: ./Source/TaurusTLSFIPS.pas
      - src: ./Source/TaurusTLSHeaders_aes.pas
      - src: ./Source/TaurusTLSHeaders_asn1.pas
      - src: ./Source/TaurusTLSHeaders_asn1err.pas
      - src: ./Source/TaurusTLSHeaders_asn1t.pas
      - src: ./Source/TaurusTLSHeaders_asn1_mac.pas
      - src: ./Source/TaurusTLSHeaders_async.pas
      - src: ./Source/TaurusTLSHeaders_asyncerr.pas
      - src: ./Source/TaurusTLSHeaders_bio.pas
      - src: ./Source/TaurusTLSHeaders_bioerr.pas
      - src: ./Source/TaurusTLSHeaders_blowfish.pas
      - src: ./Source/TaurusTLSHeaders_bn.pas
