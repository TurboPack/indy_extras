      - src: ./Source/TaurusTLSHeaders_rand.pas
      - src: ./Source/TaurusTLSHeaders_randerr.pas
      - src: ./Source/TaurusTLSHeaders_rc4.pas
      - src: ./Source/TaurusTLSHeaders_rsa.pas
